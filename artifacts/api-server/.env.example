# Port for the API server to listen on (e.g. 8080)
PORT=8080

# Secret key used to sign the session cookie (use a secure random 32+ character string in production)
SESSION_SECRET=dev-secret-change-me

# Password for the admin dashboard (e.g. purebotanica2026)
ADMIN_PASSWORD=purebotanica2024

# Environment mode (development or production)
NODE_ENV=development

# Optional: Path to the local JSON database file (defaults to ./db.json in the current working directory)
# JSON_DB_PATH=./db.json
