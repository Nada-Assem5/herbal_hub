{
  "version": 2,
  "buildCommand": "pnpm --filter @workspace/pure-botanica build",
  "outputDirectory": "artifacts/pure-botanica/dist",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
